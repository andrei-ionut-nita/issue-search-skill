.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr
.DS_Store

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim/Neovim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# Temporary editor files
*.bak
*.tmp


# ============================================================================
