__pycache__/
*.py[cod]
*$py.class
*.so

# Python environment
.Python
venv/
env/
ENV/
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Distribution artifacts
build/
dist/
*.whl
*.tar.gz

# Testing and coverage
.coverage
.pytest_cache/
htmlcov/
*.cover
.tox/


# ============================================================================
# DEVELOPMENT TOOLS & IDE
# ============================================================================

